{
  "entities": {
    "Todo": {
      "title": "Todo",
      "description": "A single todo item",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The description of the task"
        },
        "completed": {
          "type": "boolean",
          "description": "Whether the task is finished"
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this todo"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was created"
        },
        "category": {
          "type": "string",
          "enum": ["personal", "work", "shopping", "health", "other"],
          "description": "Category of the task"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Priority level"
        }
      },
      "required": ["text", "completed", "userId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Basic user profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "todos/{todoId}": {
      "schema": "Todo",
      "description": "Collection of todo items"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
